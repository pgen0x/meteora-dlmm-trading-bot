# ─── Meteora discovery ───────────────────────────────────────────────
# Base pool-discovery endpoint (rarely needs changing).
METEORA_DISCOVER_URL=https://pool-discovery-api.datapi.meteora.ag/pools
# How often to poll each enabled timeframe.
POLL_INTERVAL=60s

# ─── Hermes webhook sink ─────────────────────────────────────────────
# Where qualifying pools are POSTed. Must match your Hermes profile's
# webhook host/port + the subscription path (see assets/hermes/).
HERMES_WEBHOOK_URL=http://127.0.0.1:8646/webhooks/dlmm-signal
# Shared HMAC secret. MUST match the `secret` in webhook_subscriptions.json.
HERMES_WEBHOOK_SECRET=dlmm-signal-secret-change-me

# ─── Dedup store ─────────────────────────────────────────────────────
# Leave REDIS_ADDR empty for in-memory dedup (single instance). Set to a
# host:port to share the seen-set across restarts / instances.
REDIS_ADDR=
REDIS_SEEN_KEY=dlmm:signal:seen_pools
# Rolling window a pool stays "seen" (won't re-signal) after first emit.
SEEN_TTL=24h
# Turnover-mode override of SEEN_TTL: fast-cycle positions live minutes, so a
# still-qualifying pool may re-signal sooner (cooldowns still gate re-entry).
TURNOVER_SEEN_TTL=2h
# Casual-mode override of SEEN_TTL: positions live ~30m-2h and the monitor's
# close cooldown lapses in 1-2h, so a proven pool may re-signal the same day
# instead of being silenced for the full 24h (cooldowns still gate re-entry).
CASUAL_SEEN_TTL=6h

# ─── Mode toggles ────────────────────────────────────────────────────
ENABLE_CASUAL=true
ENABLE_MULTIDAY=true
# Turnover: small pools ($5k-$300k TVL) with 1%+ base fee turning TVL over
# fast — fee-capture plays where yield isn't capped by the trailing TP.
# Experimental; off by default until proven live (see internal/meteora/screen.go).
ENABLE_TURNOVER=false
# Fetch DexScreener momentum to reject dumping/downtrending tokens before
# emitting. Best-effort; fails open if DexScreener is unreachable.
ENABLE_MOMENTUM_GATE=true
# Fetch the Jupiter token audit per fresh candidate: hard-rejects tokens with
# >30% bot holders and enriches signals with bot % + global fees paid so the
# agent judges with the audit on-screen. Best-effort; fails open.
ENABLE_AUDIT_GATE=true
# Fetch the GMGN token snapshot per fresh candidate: smart-money/KOL holder
# counts, sniper/bundler counts, insider + bundler volume share and the dev's
# track record, attached to the signal so the agent ranks holder quality.
# Hard-rejects when insider ("rat") or bundler volume share exceeds the caps
# below — the strongest pre-rug signals available. Missing fields still pass
# (fails open). Requires a GMGN OpenAPI key (https://gmgn.ai/ai) — empty key
# disables the fetch. A cap <= 0 disables that check (enrichment stays on).
ENABLE_GMGN_GATE=true
GMGN_API_KEY=
GMGN_MAX_RAT_PCT=40
GMGN_MAX_BUNDLER_PCT=40
# Search for an established same-symbol rival token (>=500 holders, >=30 SOL
# fees, own live DLMM pool >=$5k TVL) and flag contested candidates with
# is_pvp + rival stats — ticker wars split liquidity and the copycat side
# usually loses. Advisory only (never rejects). Best-effort; fails open.
ENABLE_PVP_CHECK=true

# ─── Robinhood Chain venue (Phase 1: observe-only) ──────────────────
# Discover newly-created Uniswap v3 WETH pools on Robinhood Chain (chain ID
# 4663) via GeckoTerminal and screen them through the venue gates in
# internal/robinhood (see docs/ROBINHOOD_CHAIN_PLAN.md). Off by default.
ROBINHOOD_ENABLED=false
# GeckoTerminal new_pools endpoint override (empty = package default).
# Public tier: 30 req/min across all GeckoTerminal calls.
#ROBINHOOD_DISCOVER_URL=
# Dedup window for venue pool keys (rh:<mode>:<pool>).
ROBINHOOD_SEEN_TTL=6h
# Blockscout holder-count floor per candidate (fails open; 0 disables).
ROBINHOOD_MIN_HOLDERS=50
# Forward robinhood batches to the Hermes webhook. Default false = observe
# only (batches journal to the daemon log): the live subscription prompt and
# deploy pipeline only speak Solana, so EVM payloads stay out of them until
# the Phase 2 executor + prompt update land. GMGN gates reuse GMGN_API_KEY +
# the rat/bundler caps above; contract security (honeypot/blacklist/sell tax)
# hard-rejects on POSITIVE detection only (unknown still passes).
ROBINHOOD_WEBHOOK=false

# ─── Robinhood Chain deploy (Phase 2: live trading) ─────────────────
# Direct-deploy for this venue: the daemon runs uni_executor.js itself (the
# Solana DEPLOY_CMD pipeline is Solana-only and never sees EVM batches).
ROBINHOOD_DEPLOY_ENABLED=false
#ROBINHOOD_EXECUTOR_CMD=node /home/ubuntu/.hermes/profiles/<profile>/skills/solana-dlmm/scripts/uni_executor.js
ROBINHOOD_DEPLOY_TIMEOUT=2m
ROBINHOOD_DEPLOY_STRATEGY=balanced_tight
ROBINHOOD_RANGE_PCT=10
ROBINHOOD_SLIPPAGE_PCT=5
ROBINHOOD_MAX_OPEN_POSITIONS=2
#
# Position sizing — dynamic, read from the live wallet before every deploy
# (robinhood.ComputeDeployAmount), the port of dlmm_pipeline.py's
# compute_deploy_amount. Replaces the old fixed ROBINHOOD_DEPLOY_AMOUNT_WETH,
# which minted a flat 0.003 WETH no matter the balance (~17% of a 0.0174 WETH
# wallet) and never scaled as the wallet grew.
#
#   deployable = weth_balance - RESERVE
#   amount     = clamp(deployable * PCT, FLOOR, CEIL)   # 0 => skip the deploy
#
# Taking a PERCENTAGE of the remaining balance is the point: each open position
# shrinks the base for the next, so exposure tapers as positions stack.
ROBINHOOD_DEPLOY_RESERVE_WETH=0.002
ROBINHOOD_DEPLOY_PCT=0.45
# Floor = smallest position worth its gas + round-trip swap cost. Below it the
# deploy is SKIPPED, not shrunk to dust.
ROBINHOOD_DEPLOY_FLOOR_WETH=0.003
# Per-position hard cap while the venue is young; raise as its close journal grows.
ROBINHOOD_DEPLOY_CEIL_WETH=0.05
# Native-ETH gas floor. This venue pays gas in ETH but LPs in WETH (unlike
# Solana, where SOL is both), so a WETH-rich wallet can still be too broke to
# mint. Fails closed below this.
ROBINHOOD_MIN_GAS_ETH=0.0002

# ─── Conviction gates ────────────────────────────────────────────────
# A cycle that produces exactly ONE fresh candidate must score at least this
# (0-100 degen score) to be emitted — "only option" is not "good option".
# Held-back pools are unmarked so they can join a future, richer batch.
# 0 disables the gate.
LONE_MIN_SCORE=50

# ─── Direct deploy (deterministic picker) ────────────────────────────
# When DEPLOY_CMD is set the daemon SKIPS the Hermes agent webhook and runs
# this command per batch with `--from-batch <payload JSON> --mode <mode>`
# appended. The pipeline re-ranks the batch deterministically (GMGN/PVP/
# prior-PnL heuristics + darwinian signal weights) and deploys the strongest
# candidate that clears every live gate, falling back to the runner-up when a
# gate rejects the pick. Decision latency drops from an LLM agent turn
# (observed 19-54 min) to seconds. Empty = webhook flow (default).
# The command is whitespace-split; paths must not contain spaces. Wallet keys
# stay in the Hermes profile .env — the executor loads them itself.
#DEPLOY_CMD=python3 /path/to/profile/skills/solana-dlmm/scripts/dlmm_pipeline.py
# Upper bound for one direct-deploy run (pre-swap + on-chain deploy).
DEPLOY_TIMEOUT=5m
# Optional delivery for direct-deploy outcome reports (text on stdin), e.g.
# `hermes send -t telegram` — no LLM, reuses the gateway's bot credentials.
# Empty = outcomes only appear in the daemon log.
#REPORT_CMD=hermes send -t telegram
# Also deliver REJECT outcomes (deploys are always delivered). Default off:
# re-signalling modes reject every few cycles and the log already has them.
REPORT_REJECTS=false
