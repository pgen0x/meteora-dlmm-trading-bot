# ─── Meteora discovery ───────────────────────────────────────────────
# Base pool-discovery endpoint (rarely needs changing).
METEORA_DISCOVER_URL=https://pool-discovery-api.datapi.meteora.ag/pools
# How often to poll each enabled timeframe.
POLL_INTERVAL=60s

# ─── Hermes webhook sink ─────────────────────────────────────────────
# Where qualifying pools are POSTed. Must match your Hermes profile's
# webhook host/port + the subscription path (see assets/hermes/).
HERMES_WEBHOOK_URL=http://127.0.0.1:8646/webhooks/dlmm-signal
# Shared HMAC secret. MUST match the `secret` in webhook_subscriptions.json.
HERMES_WEBHOOK_SECRET=dlmm-signal-secret-change-me

# ─── Dedup store ─────────────────────────────────────────────────────
# Leave REDIS_ADDR empty for in-memory dedup (single instance). Set to a
# host:port to share the seen-set across restarts / instances.
REDIS_ADDR=
REDIS_SEEN_KEY=dlmm:signal:seen_pools
# Rolling window a pool stays "seen" (won't re-signal) after first emit.
SEEN_TTL=24h

# ─── Mode toggles ────────────────────────────────────────────────────
ENABLE_CASUAL=true
ENABLE_MULTIDAY=true
# Fetch DexScreener momentum to reject dumping/downtrending tokens before
# emitting. Best-effort; fails open if DexScreener is unreachable.
ENABLE_MOMENTUM_GATE=true
