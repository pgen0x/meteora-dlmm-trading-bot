/dist/

# Secrets / local config
# Glob, not a bare `.env`: that left `.env.bak`, `.env.local`, `.env.2026-07-13`
# untracked BUT committable — and this repo's .env holds wallet private keys.
# .env.example is the one non-secret template, force-tracked below.
.env*
!.env.example

# Go
/vendor/

# Python bytecode
__pycache__/
*.pyc

# npm deps for the solana-dlmm skill (installed at repo level so dlmm_executor.js's
# require() resolution finds them through the scripts/ symlink into Hermes profiles)
assets/skill/node_modules/
